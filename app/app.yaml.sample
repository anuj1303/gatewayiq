# =============================================================================
# SAMPLE of the app.yaml that render_config.py GENERATES from customer.yaml.
# This is for reference only — you do NOT edit this file; `./install.sh` (or
# render_config.py) writes the real app.yaml from your customer.yaml.
# The db + secret RESOURCES are declared in databricks.yml (the bundle), not here.
# Values below correspond to the sample "Acme" customer.yaml.example.
# =============================================================================
# GENERATED from customer.yaml by render_config.py — do not edit by hand.
command: ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]

env:
  - name: "PGHOST"
    value: "instance-8f2c19a4-3b7d-4e51-9c02-a1b2c3d4e5f6.database.cloud.databricks.com"
  - name: "PGDATABASE"
    value: "gatewayiq"
  - name: "PGPORT"
    value: "5432"
  - name: "PGSSLMODE"
    value: "require"
  - name: "APP_SP_ROLE"
    value: "11111111-2222-3333-4444-555555555555"
  - name: "APP_URL"
    value: "https://gatewayiq-1234567890.aws.databricksapps.com"
  - name: "EMAIL_DOMAIN"
    value: "acme.com"
  - name: "ADMIN_EMAILS"
    value: "ai-governance-admin@acme.com,platform-lead@acme.com"
  - name: "IDENTITY_SOURCE"
    value: "directory"
  - name: "SOURCE_INFERENCE_TABLE"
    value: "acme_ai_gov.gateway.inference_logs"
  - name: "SOURCE_DIRECTORY_TABLE"
    value: "acme_hr.people.directory"
  - name: "SOURCE_USAGE_TABLE"
    value: "system.serving.endpoint_usage"
  - name: "UC_CATALOG"
    value: "acme_ai_gov"
  - name: "UC_SCHEMA"
    value: "gatewayiq"
  - name: "CLASSIFIER_MODEL"
    value: "databricks-claude-haiku-4-5"
  - name: "MODEL_PRICING"
    value: "{\"models\":{\"databricks-claude-opus-4-1\":{\"input\":15.0,\"output\":75.0,\"tier\":\"premium\"},\"databricks-claude-sonnet-4-6\":{\"input\":3.0,\"output\":15.0,\"tier\":\"premium\"},\"databricks-claude-3-7-sonnet\":{\"input\":3.0,\"output\":15.0,\"tier\":\"premium\"},\"databricks-claude-haiku-4-5\":{\"input\":0.8,\"output\":4.0,\"tier\":\"standard\"},\"databricks-meta-llama-3-1-405b-instruct\":{\"input\":5.0,\"output\":15.0,\"tier\":\"premium\"},\"databricks-meta-llama-3-3-70b-instruct\":{\"input\":1.0,\"output\":3.0,\"tier\":\"standard\"},\"databricks-meta-llama-3-1-8b-instruct\":{\"input\":0.5,\"output\":1.5,\"tier\":\"standard\"},\"databricks-dbrx-instruct\":{\"input\":0.75,\"output\":2.25,\"tier\":\"standard\"},\"databricks-mixtral-8x7b-instruct\":{\"input\":0.5,\"output\":1.0,\"tier\":\"standard\"},\"databricks-gemma-3-12b\":{\"input\":0.3,\"output\":0.6,\"tier\":\"standard\"},\"databricks-gte-large-en\":{\"input\":0.1,\"output\":0.0,\"tier\":\"embedding\"},\"databricks-bge-large-en\":{\"input\":0.1,\"output\":0.0,\"tier\":\"embedding\"}},\"default\":{\"input\":1.0,\"output\":5.0,\"tier\":\"standard\"},\"ui\":{\"expensive_label\":\"Premium models\",\"cheap_label\":\"Standard models\"}}"
  - name: "MAIL_FROM_NAME"
    value: "GatewayIQ"
  - name: "MAIL_FROM_EMAIL"
    value: "ai-gateway-reports@acme.com"
  - name: "GOOGLE_QUOTA_PROJECT"
    value: "acme-gcp-project"
  - name: "GMAIL_CLIENT_ID"
    valueFrom: "gmail-client-id"
  - name: "GMAIL_CLIENT_SECRET"
    valueFrom: "gmail-client-secret"
  - name: "GMAIL_REFRESH_TOKEN"
    valueFrom: "gmail-refresh-token"
